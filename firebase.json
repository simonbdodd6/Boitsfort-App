{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**"
    ],
    "rewrites": [
      {
        "source": "/api/frameStats",
        "function": {
          "functionId": "frameStats",
          "region": "europe-west1"
        }
      },
      {
        "source": "/api/frameDebug",
        "function": {
          "functionId": "frameDebug",
          "region": "europe-west1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
